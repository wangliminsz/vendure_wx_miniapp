project.private.config.json
# VSCode 编辑器配置（你项目里的 .vscode 文件夹）
.vscode/
# WebStorm/IDEA 等其他IDE配置
.idea/
*.iml

# ==============================================
# 3. 依赖包与构建产物
# ==============================================
# Node.js 依赖
node_modules/
# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# 本地环境变量文件
.env.local
.env.*.local

# ==============================================
