    <!-- 客户留言 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">客户留言</text>
      </view>
      <textarea class="message-input" placeholder="请输入您的留言（选填）" bindinput="onMessageInput" value="{{customerMessage}}" maxlength="200"></textarea>
    </view>


    <!-- 联系客服 -->
    <view class="section customer-service">
      <view class="section-header">
        <text class="section-title">联系客服</text>
      </view>
      <view class="service-info">
        <text class="service-text">任何未尽事宜，请联系客服确认</text>
        <!-- <text class="service-contact">客服微信：XXX</text> -->
      </view>
    </view>
    

  </view>



</view>