<view class="page-container">
  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-overlay">
    <view class="loading-content">
      <!-- <view class="loading-spinner"></view> -->
      <!-- <text class="loading-text">加载中...</text> -->
    </view>
  </view>

  <!-- 顶部用户信息大卡片（全信息展示） -->
  <view class="user-card" wx:if="{{!isLoading}}">
    <view class="user-info">
      <!-- 头像 -->
      <image class="avatar" src="{{userAvatarUrl}}" mode="aspectFill"></image>
      <!-- 信息区域：昵称 + 姓名 + 手机号 分层展示 -->
      <view class="user-text">
        <view class="flex justify-between">
          <view>
            <view class="user-nickname mb-2" wx:if="{{userNickName}}">
              {{userNickName}}
            </view>
            <view class="user-nickname placeholder" bindtap="updateUserInfo2" wx:else>
              点击注册
            </view>
            <view class="user-name mb-2" wx:if="{{userName}}">姓名：{{userName}}</view>
            <view class="user-phone" wx:if="{{userMobile}}">手机号：{{userMobile}}</view>
          </view>

          <!-- 右侧状态 + 地址管理入口 -->
          <view class="right-actions">
            <!-- Vendure用户注册状态 -->
            <view wx:if="{{userNickName}}">
              <view class="vendure-status {{isLogin ? 'registered' : 'unregistered'}}">
                <text wx:if="{{isLogin}}">✅ 已登录</text>
                <text wx:else bindtap="updateUserInfo2">点击注册</text>
              </view>
            </view>

            <!-- 新增：地址管理入口（仅已登录显示） -->
            <view wx:if="{{isLogin}}" class="address-entry" bindtap="goToAddress">
              <!-- 线性地址图标 + 文字 -->
              <view class="address-icon">📍</view>
              <text class="address-text">地址管理</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮组（宽松大间距） -->
  <view class="btn-group">
    <!-- 仅已登录用户显示地址管理按钮 -->
    <!-- <button wx:if="{{isLogin}}" class="btn-address" bindtap="goToAddress">地址管理</button> -->
    <button class="btn-primary" bindtap="updateUserInfo2">注册/更新</button>
    <button class="btn-default" bindtap="returnToHome">返回首页</button>
  </view>

  <!-- 底部协议 -->
  <view class="agreement">
    <navigator url="/pages/userAgreement/userAgreement" class="link">用户服务协议</navigator>
    <view class="line"></view>
    <navigator url="/pages/privacyPolicy/privacyPolicy" class="link">隐私政策</navigator>
  </view>
</view>