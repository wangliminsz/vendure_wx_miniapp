.container {
  min-height: 100vh;
  background-color: #165DFF;
  padding: 0;
}

.logo-section {
  background: linear-gradient(135deg, #165DFF 0%, #4080FF 100%);
  padding: 120rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  background-color: #ffffff;
  margin: -40rpx 32rpx 0;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #1D2129;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #F2F3F5;
  border-radius: 44rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.code-input-wrapper {
  display: flex;
  gap: 16rpx;
}

.code-input-wrapper .form-input {
  flex: 1;
}

.send-code-btn {
  background-color: #165DFF;
  color: #ffffff;
  padding: 0 24rpx;
  border-radius: 44rpx;
  font-size: 26rpx;
  white-space: nowrap;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-code-btn.disabled {
  background-color: #86909C;
}

.login-btn {
  background-color: #165DFF;
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 32rpx;
}

.login-btn[disabled] {
  background-color: #86909C;
}

.agreement {
  margin-top: 24rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #86909C;
  margin-left: 8rpx;
}

.link {
  color: #165DFF;
}

.other-login {
  padding: 48rpx 32rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-methods {
  display: flex;
  justify-content: center;
}

.login-method {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-method image {
  width: 96rpx;
  height: 96rpx;
  background-color: #ffffff;
  border-radius: 48rpx;
  margin-bottom: 12rpx;
}

.login-method text {
  font-size: 24rpx;
  color: #ffffff;
}
