.container {
  min-height: 100vh;
  background-color: #F2F3F5;
  padding-bottom: 140rpx;
}

.section {
  background-color: #ffffff;
  margin-bottom: 16rpx;
  padding: 24rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
}

.section-count {
  font-size: 26rpx;
  color: #86909C;
}

.address-section {
  padding: 0;
}

.section-content {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 24rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.receiver {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
}

.phone {
  font-size: 28rpx;
  color: #1D2129;
}

.address-detail {
  font-size: 26rpx;
  color: #86909C;
  line-height: 1.5;
}

.no-address {
  flex: 1;
  font-size: 28rpx;
  color: #86909C;
}

.section-arrow {
  font-size: 32rpx;
  color: #86909C;
}

.product-list {
  display: flex;
  flex-direction: column;
}

.product-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: #1D2129;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.product-sku {
  font-size: 22rpx;
  color: #86909C;
}

.product-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.product-price {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.product-qty {
  font-size: 24rpx;
  color: #86909C;
}

.price-list {
  display: flex;
  flex-direction: column;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #86909C;
}

.price-value {
  font-size: 28rpx;
  color: #1D2129;
}

.price-value.discount {
  color: #00B42A;
}

.price-row.total {
  border-top: 1rpx solid #F2F3F5;
  padding-top: 24rpx;
  margin-top: 12rpx;
}

.price-value.total {
  font-size: 36rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.payment-icon {
  width: 48rpx;
  height: 48rpx;
}

.payment-left text {
  font-size: 28rpx;
  color: #1D2129;
}

.remark-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background-color: #F2F3F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1D2129;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.total-section {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 28rpx;
  color: #1D2129;
}

.total-price {
  font-size: 36rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.submit-btn {
  background-color: #165DFF;
  color: #ffffff;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn[disabled] {
  background-color: #86909C;
}
