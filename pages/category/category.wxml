<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input" bindtap="goToSearch">
      <image src="/static/icons/search.png" mode="aspectFit" style="width: 32rpx; height: 32rpx;"></image>
      <input type="text" placeholder="搜索型号/品牌/物料编码" disabled />
    </view>
  </view>

  <!-- 分类内容 -->
  <view class="category-content">
    <!-- 左侧分类导航 -->
    <scroll-view class="category-left" scroll-y enhanced>
      <view
        class="category-item {{activeCategory === index ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="onCategoryTap"
        data-index="{{index}}"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧商品列表 -->
    <scroll-view class="category-right" scroll-y enhanced bindscrolltolower="onReachBottom" bindscroll="onScroll" scroll-top="{{scrollTop}}" lower-threshold="50">
      <!-- 商品列表 -->
      <view class="product-list">
        <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="goToProduct" data-id="{{item.id}}">
          <image src="{{item.image}}" mode="aspectFill" class="product-image"></image>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-brand">{{item.brand}}</text>
            <text class="product-sku">料号: {{item.sku}}</text>
            <view class="product-footer">
              <view class="product-prices">
                <text class="product-price">¥{{item.price}}</text>
                <text class="product-volume-price" wx:if="{{item.volumePrice}}">批量: ¥{{item.volumePrice}}</text>
              </view>
              <text class="product-stock">库存: {{item.stock}}</text>
            </view>
            <view class="product-meta">
              <text class="product-moq">起订: {{item.moq}}</text>
              <text class="product-lead-time">交期: {{item.leadTime}}</text>
            </view>
          </view>
          <view class="product-action">
            <text class="add-cart-btn" bindtap="onAddToCart" data-id="{{item.id}}">加入采购车</text>
          </view>
        </view>
      </view>

      <view style="margin-top: 10px;"></view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
        <text>该分类暂无商品</text>
      </view>
    </scroll-view>

    <!-- 回到顶部按钮 -->
    <view wx:if="{{showBackToTop}}" class="back-to-top" bindtap="scrollToTop">
      <image src="/static/images/up-arrow.svg" mode="aspectFit" class="back-to-top-icon"></image>
    </view>
  </view>
</view>
