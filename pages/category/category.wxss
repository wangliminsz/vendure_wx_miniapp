.container {
  min-height: 100vh;
  background-color: #F2F3F5;
  display: flex;
  flex-direction: column;
}

.search-bar {
  background-color: #165DFF;
  padding: 16rpx 32rpx 24rpx;
}

.search-input {
  background-color: #ffffff;
  border-radius: 36rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.search-input image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.search-input input {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.category-content {
  flex: 1;
  display: flex;
  height: calc(100vh - 108rpx);
  overflow: hidden;
}

.category-left {
  width: 180rpx;
  background-color: #ffffff;
  border-right: 1rpx solid #F2F3F5;
}

.category-item {
  padding: 32rpx 16rpx;
  font-size: 26rpx;
  color: #1D2129;
  text-align: center;
  border-left: 6rpx solid transparent;
}

.category-item.active {
  background-color: #F2F3F5;
  color: #165DFF;
  font-weight: bold;
  border-left-color: #165DFF;
}

.category-right {
  flex: 1;
  background-color: #F2F3F5;
  padding: 16rpx;
  height: calc(100vh - 108rpx);
  overflow-y: auto;
  box-sizing: border-box;
}

.filter-bar {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.filter-item {
  flex: 1;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #1D2129;
  border-right: 1rpx solid #F2F3F5;
}

.filter-item:last-child {
  border-right: none;
}

.filter-arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #86909C;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  gap: 16rpx;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: #1D2129;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.product-brand {
  font-size: 24rpx;
  color: #165DFF;
  margin-bottom: 4rpx;
}

.product-sku {
  font-size: 22rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 8rpx;
}

.product-prices {
  display: flex;
  flex-direction: column;
}

.product-price {
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.product-volume-price {
  font-size: 22rpx;
  color: #00B42A;
}

.product-stock {
  font-size: 22rpx;
  color: #86909C;
}

.product-meta {
  display: flex;
  gap: 16rpx;
}

.product-moq {
  font-size: 22rpx;
  color: #165DFF;
}

.product-lead-time {
  font-size: 22rpx;
  color: #86909C;
}

.product-action {
  display: flex;
  align-items: flex-end;
}

.add-cart-btn {
  background-color: #165DFF;
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state text {
  color: #86909C;
  font-size: 28rpx;
}

.back-to-top {
  aspect-ratio: 1 / 1;
  position: fixed;
  bottom: 200rpx;
  right: 30rpx;
  width: 90rpx;
  height: 90rpx;
  background-color: transparent;
  border: 2rpx solid rgba(100, 100, 100, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.back-to-top-icon {
  width: 50rpx;
  height: 50rpx;
}
