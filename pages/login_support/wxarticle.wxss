.container {
  height: 100vh;
  background-color: #f0f0f0;
  /* padding: 0; */
  /* margin-top: 20px; */
  box-sizing: border-box;
  /* margin-left: 5%;
  margin-right: 5%; */
}

.content {
  display: flex;
  flex-direction: column;
  /* background-color: #f5f5f5; */
  width: 100%;
  height: 100%;
  margin-left: 5%;
  margin-right: 5%;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 20px;
  width: 90%; /* Ensure full width */
  margin-bottom: 40px;
  margin-left: 5%;
  margin-right: 5%;
}

.input {
  width: 100%;
  height: 50px;
  background-color: #fff;
  border: 1px solid #333;
  border-radius: 5px;
  padding: 0 15px; /* Increased horizontal padding */
  font-size: 14px;
  box-sizing: border-box; /* Ensure padding is included in width */
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.button {
  width: 100%;
  height: 40px;
  border-radius: 5px;
  color: #fff;
  font-size: 16px;
  border: none;
}

.submit {
  background-color: #4CAF50;
}

.clear {
  background-color: #f44336;
}