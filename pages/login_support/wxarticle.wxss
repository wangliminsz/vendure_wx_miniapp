.alerts-container {
  margin-top: 40px;
  margin-left: 20px;
  width: 90%;
}

.alert-card {
  background-color: #e0e0f0;
  border-radius: 5px;
  padding: 10px;
  margin-bottom: 10px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 20px;
}

.alert-info {
  display: flex;
  /* justify-content: space-between; */
  flex-grow: 1;
}

.alert-text {
  font-size: 14px;
  color: #333;
  margin-left: 5px;
  margin-right: 20px;
}

.delete-icon {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background-color: #ff4d4f;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 10px;
}

.icon {
  color: white;
  font-size: 16px;
  line-height: 1;
}

