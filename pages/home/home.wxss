.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.hero-section {
  width: 100%;
  position: relative;
}

.hero-swiper {
  width: 100%;
  height: 400rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
  padding: 40rpx 24rpx 24rpx;
  border-radius: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.collections-section {
  padding: 24rpx;
  margin-top: 10px;
  background-color: #f5f5f5;
}

.collections-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.collection-card {
  width: calc(33.33% - 12rpx);
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  padding-bottom: 10px;
}

.collection-image-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
  margin-top: 6px;
}

.collection-image {
  width: 60%;
  height: 100rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.collection-info {
  text-align: center;
}

.collection-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.collection-count {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 6px;
}

.collection-texts {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
  gap: 12rpx;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.order-history-link {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.order-btn {
  width: 100%;
  height: 88rpx;
  background-color: #1677FF;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}