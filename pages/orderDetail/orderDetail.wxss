.container {
  min-height: 100vh;
  background-color: #F2F3F5;
  padding-bottom: 140rpx;
}

.order-status-card {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-status-card.status-pending {
  background: linear-gradient(135deg, #FF7D00 0%, #FFA500 100%);
}

.order-status-card.status-paid {
  background: linear-gradient(135deg, #165DFF 0%, #4080FF 100%);
}

.order-status-card.status-shipped {
  background: linear-gradient(135deg, #00B42A 0%, #23D27A 100%);
}

.order-status-card.status-completed {
  background: linear-gradient(135deg, #86909C 0%, #A6ACB2 100%);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.status-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.address-card {
  background-color: #ffffff;
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.address-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.receiver {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
}

.phone {
  font-size: 28rpx;
  color: #1D2129;
}

.address-detail {
  font-size: 26rpx;
  color: #86909C;
  line-height: 1.5;
}

.product-list-card,
.order-info-card,
.price-detail-card {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
}

.product-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: #1D2129;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.product-sku {
  font-size: 22rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.product-meta {
  display: flex;
  gap: 16rpx;
}

.product-brand,
.product-moq {
  font-size: 22rpx;
  color: #165DFF;
}

.product-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.product-price {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.product-qty {
  font-size: 24rpx;
  color: #86909C;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #86909C;
}

.info-value {
  font-size: 28rpx;
  color: #1D2129;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #86909C;
}

.price-value {
  font-size: 28rpx;
  color: #1D2129;
}

.price-value.discount {
  color: #00B42A;
}

.price-row.total {
  border-top: 1rpx solid #F2F3F5;
  padding-top: 24rpx;
  margin-top: 12rpx;
}

.price-value.total {
  font-size: 36rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  background-color: #ffffff;
  color: #1D2129;
  border: 1rpx solid #E5E6EB;
  border-radius: 44rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.action-btn.secondary {
  background-color: #ffffff;
  color: #165DFF;
  border: 1rpx solid #165DFF;
}

.action-btn.primary {
  background-color: #165DFF;
  color: #ffffff;
  border: none;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}
