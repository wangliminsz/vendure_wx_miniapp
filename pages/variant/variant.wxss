/* 全局基础规范：统一页面背景，告别割裂 */
.container {
  min-height: 100vh;
  /* 🔑 核心：用极浅的中性灰做全页背景，比纯白更柔和，比深灰更干净 */
  background-color: #FAFBFC;
  padding-bottom: 140rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #E5E6EB;
  border-top-color: #165DFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #86909C;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #FFF2F0;
  color: #FF4D4F;
  font-size: 60rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.error-btn {
  margin-top: 32rpx;
  background-color: #165DFF;
  color: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: none;
}

.variant-content {
  padding-top: 20rpx;
  padding-bottom: 140rpx;
}

/* 商品信息区：和图片区做圆角衔接，完全融为一体 */
.product-info {
  background-color: #ffffff;
  margin: 0;
  padding: 32rpx;
  /* 🔑 核心：只给顶部加圆角，底部完全直角，和图片区无缝对接 */
  border-radius: 0 0 0 0;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 0;
}

.product-header {
  margin-bottom: 24rpx;
}

.product-name {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #1D2129;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.product-subtitle {
  display: block;
  font-size: 28rpx;
  color: #86909C;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.product-price {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF4D4F;
}

.meta-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-top: 1rpx solid #F2F3F5;
  border-bottom: 1rpx solid #F2F3F5;
  margin-bottom: 10rpx;
}

.product-sku {
  font-size: 26rpx;
  color: #86909C;
}

.stock-status {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.stock-in {
  background-color: #E6F7E6;
  color: #00B42A;
}

.stock-low {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.stock-out {
  background-color: #FFF2F0;
  color: #FF4D4F;
}

.product-description {
  margin-bottom: 24rpx;
}

.description-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 16rpx;
}

/* 错误提示 */
.error-tip {
  background-color: #FFF7E6;
  border: 1rpx solid #FFE082;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
}

.error-tip-content {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.error-tip-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #FA8C16;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.error-tip-text {
  font-size: 26rpx;
  color: #92400E;
  line-height: 1.5;
}

.error-tip-close {
  font-size: 40rpx;
  color: #86909C;
  padding-left: 16rpx;
}

/* 数量选择区 */
.quantity-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #F7F8FA;
  border-radius: 16rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #E5E6EB;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1D2129;
  transition: all 0.2s ease;
}

.quantity-btn:active {
  background-color: #F2F3F5;
}

.quantity-btn.minus {
  border-right: 1rpx solid #E5E6EB;
  border-radius: 16rpx 0 0 16rpx;
}

.quantity-btn.plus {
  border-left: 1rpx solid #E5E6EB;
  border-radius: 0 16rpx 16rpx 0;
}

.quantity-input {
  width: 100rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1D2129;
  padding: 0;
}

/* 商品图片区：和信息区无缝衔接，完全融为一体 */
.product-images {
  background-color: #ffffff;
  padding: 32rpx 0;
  margin-bottom: 16rpx;
  /* 🔑 核心：顶部完全直角，和信息区的底部圆角完美贴合，无任何缝隙 */
  border-radius: 0;
  box-shadow: none;
}

.main-image-container {
  position: relative;
  width: 100%;
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
}

.main-image {
  width: 100%;
  height: 100%;
}

.no-image {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #86909C;
  font-size: 28rpx;
}

.image-nav {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  padding: 0 16rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.nav-icon {
  font-size: 40rpx;
  color: #1D2129;
  font-weight: bold;
}

.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}

.thumbnail-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  justify-content: center;
}

.thumbnail-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.thumbnail-item.active {
  border-color: #165DFF;
  transform: scale(1.05);
}

.thumbnail-image {
  width: 100%;
  height: 100%;
}

/* 底部固定操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-icons {
  display: flex;
  gap: 32rpx;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-icon-item image {
  width: 60rpx;
  height: 60rpx;
}

.action-icon-item text {
  font-size: 22rpx;
  color: #86909C;
}

.cart-icon {
  position: relative;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff4757;
  color: white;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.action-buttons {
  flex: 1;
  margin-left: 32rpx;
}

.btn-add-cart {
  width: 100%;
  background-color: #165DFF;
  color: #ffffff;
  padding: 28rpx 48rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  height: 88rpx;
  line-height: 1;
  transition: all 0.2s ease;
}

.btn-add-cart:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-add-cart[disabled] {
  background-color: #94A3B8;
  opacity: 0.7;
}