/* ========== 全局 ========== */

.page {
  background-color: #FAFBFC;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 14px;
  line-height: 1.5;
  color: #1D2129;
}

.container {
  min-height: 100vh;
  background-color: #FAFBFC;
  padding-bottom: 140rpx;
}

/* ========== 主体内容 ========== */
.variant-content {
  padding-top: 0;     /* REMOVE TOP GAP ✅ */
  /* padding-bottom: 60rpx; */
}

/* ========== 商品图片区 ========== */
.product-images {
  background-color: #ffffff;
  margin: 0 0 4px;
  padding: 0;
  border-radius: 0;
  box-shadow: none;
}

.main-image-container {
  position: relative;
  width: 100%;
  height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 0;
  overflow: hidden;
}

.main-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}












.no-image {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #86909C;
  font-size: 14px;
}

.image-nav {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  padding: 0 16rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.nav-icon {
  font-size: 40rpx;
  color: #1D2129;
  font-weight: bold;
}

.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 12px;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}

.thumbnail-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding: 24rpx 32rpx;
  justify-content: center;
}

.thumbnail-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8px;
  overflow: hidden;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.thumbnail-item.active {
  border-color: #165DFF;
  transform: scale(1.05);
}

.thumbnail-image {
  width: 100%;
  height: 100%;
}

/* ========== 商品信息区 ========== */
.product-info {
  background-color: #ffffff;
  margin: 0 16px 12px;
  padding: 16px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid #F2F3F5;
}

.product-header {
  margin-bottom: 12px;
}

.product-name {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #1D2129;
  line-height: 1.4;
  margin-bottom: 8px;
}

.product-subtitle {
  display: block;
  font-size: 14px;
  color: #86909C;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin-bottom: 6px;
}

.product-price {
  font-size: 20px;
  /* font-weight: bold; */
  color: #FF7D00;
}

.meta-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-top: 1rpx solid #F2F3F5;
  border-bottom: 1rpx solid #F2F3F5;
  margin-bottom: 12px;
}

.product-sku {
  font-size: 12px;
  color: #86909C;
}

.stock-status {
  font-size: 12px;
  padding: 8rpx 16rpx;
  border-radius: 8px;
  font-weight: 500;
}

.stock-in {
  background-color: #E8F8F0;
  color: #00B42A;
}

.stock-low {
  background-color: #FFF3E0;
  color: #FF7D00;
}

.stock-out {
  background-color: #FFF2F0;
  color: #FF4D4F;
}

.product-description {
  margin-bottom: 12px;
}

.description-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12px;
}

/* ========== 技术文档区域 ========== */
.docs-section {
  margin: 40px 16px 12px;
  padding: 16px;
  background-color: #F7F8FA;
  border-radius: 8px;
  border: 1px solid #E5E6EB;
}

.docs-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12px;
}

.docs-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.file_icon-container {
  width: 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.file_icon {
  width: 48px;
  height: 48px;
  flex-shrink: 0;
}

.doc-name {
  font-size: 12px;
  color: #1D2129;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

/* ========== 错误提示 ========== */
.error-tip {
  background-color: #FFF7E6;
  border: 1rpx solid #FFE082;
  border-radius: 8px;
  padding: 16px;
  margin: 0 16px 12px;
  display: flex;
  align-items: flex-start;
}

.error-tip-content {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.error-tip-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #FA8C16;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.error-tip-text {
  font-size: 14px;
  color: #92400E;
  line-height: 1.5;
}

.error-tip-close {
  font-size: 40rpx;
  color: #86909C;
  padding-left: 16rpx;
}

/* ========== 数量选择区 ========== */
.quantity-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px;
  background-color: #F7F8FA;
  border-radius: 8px;
  margin: 0 16px 30px;
  border: 1px solid #E5E6EB;
}

.quantity-label {
  font-size: 14px;
  color: #1D2129;
  font-weight: 500;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 8px;
  border: 1px solid #E5E6EB;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #1D2129;
  transition: all 0.2s ease;
}

.quantity-btn:active {
  background-color: #F2F3F5;
}

.quantity-btn.minus {
  border-right: 1rpx solid #E5E6EB;
  border-radius: 8px 0 0 8px;
}

.quantity-btn.plus {
  border-left: 1rpx solid #E5E6EB;
  border-radius: 0 8px 8px 0;
}

.quantity-input {
  width: 100rpx;
  text-align: center;
  font-size: 14px;
  color: #1D2129;
  padding: 0;
  background: transparent;
  border: none;
}

/* ========== 底部固定操作栏 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.08);
  border-top: 1px solid #F2F3F5;
}

.action-icons {
  display: flex;
  gap: 32rpx;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-icon-item image {
  width: 60rpx;
  height: 60rpx;
}

.action-icon-item text {
  font-size: 12px;
  color: #86909C;
}

.cart-icon {
  position: relative;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff4757;
  color: white;
  font-size: 12px;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.action-buttons {
  flex: 1;
  margin-left: 32rpx;
}

.btn-add-cart {
  width: 100%;
  background-color: #165DFF;
  color: #ffffff;
  padding: 12px 24px;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  border: none;
  height: 48px;
  line-height: 1.4;
  transition: all 0.2s ease;
}

.btn-add-cart:active {
  opacity: 0.9;
}

.btn-add-cart[disabled] {
  background-color: #94A3B8;
  opacity: 0.7;
}
















/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #E5E6EB;
  border-top-color: #165DFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 12px;
  color: #86909C;
}

/* ========== 错误状态 ========== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #FFF2F0;
  color: #FF4D4F;
  font-size: 60rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-text {
  margin-top: 32rpx;
  font-size: 14px;
  color: #1D2129;
}

.error-btn {
  margin-top: 32rpx;
  background-color: #165DFF;
  color: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 8px;
  font-size: 16px;
  border: none;
  height: 48px;
  line-height: 1;
}