.back-to-top {
  aspect-ratio: 1 / 1;
  position: fixed;
  bottom: 200rpx;
  right: 30rpx;
  width: 90rpx;
  height: 90rpx;
  background-color: transparent;
  /* border: 2rpx solid rgba(100, 100, 100, 0.5); */
  /* border-radius: 50%; */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.back-to-top-icon {
  width: 50rpx;
  height: 50rpx;
}

