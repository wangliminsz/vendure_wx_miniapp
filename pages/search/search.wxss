.container {
  min-height: 100vh;
  background-color: #F2F3F5;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F2F3F5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.search-clear {
  font-size: 40rpx;
  color: #86909C;
  line-height: 1;
}

.search-cancel {
  font-size: 28rpx;
  color: #165DFF;
  white-space: nowrap;
}

.search-history {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1D2129;
}

.section-action {
  font-size: 26rpx;
  color: #86909C;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  background-color: #F2F3F5;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #1D2129;
}

.hot-search {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.hot-list {
  display: flex;
  flex-direction: column;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  width: 48rpx;
  font-size: 28rpx;
  color: #86909C;
  font-weight: bold;
}

.hot-rank.top {
  color: #FF4D4F;
}

.hot-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hot-keyword {
  font-size: 28rpx;
  color: #1D2129;
}

.hot-count {
  font-size: 22rpx;
  color: #86909C;
}

.search-results {
  padding: 16rpx;
}

.results-header {
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #86909C;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  gap: 16rpx;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: #1D2129;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.product-brand {
  font-size: 24rpx;
  color: #165DFF;
  margin-bottom: 4rpx;
}

.product-sku {
  font-size: 22rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.product-price {
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.product-stock {
  font-size: 22rpx;
  color: #86909C;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #86909C;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #86909C;
  font-size: 28rpx;
}
