.container {
  height: 100vh;
  background-color: #F2F3F5;
  display: flex;
  flex-direction: column;
}

.search-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.search-bar {
  background-color: #165DFF;
  padding: 26rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.search-input-wrapper {
  flex: 1;
  background-color: #ffffff;
  border-radius: 16rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
}

.search-input-wrapper input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #E5E6EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.clear-icon {
  font-size: 32rpx;
  color: #86909C;
  line-height: 1;
}

.search-cancel-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(100, 100, 100, 0.5);
  background-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.cancel-icon {
  font-size: 24rpx;
  color: rgba(100, 100, 100, 0.5);
  line-height: 1;
}

.search-button-wrapper {
  flex-shrink: 0;
}

.search-btn {
  background-color: #ffffff;
  color: #165DFF;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 24rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  white-space: nowrap;
}

.search-history {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
}

.section-action {
  font-size: 26rpx;
  color: #86909C;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  background-color: #F2F3F5;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4E5969;
}

.hot-search {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.hot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hot-item {
  display: flex;
  align-items: center;
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background-color: #F2F3F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #86909C;
  margin-right: 20rpx;
}

.hot-rank.top {
  background-color: #FF7D00;
  color: #fff;
}

.hot-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hot-keyword {
  font-size: 28rpx;
  color: #1D2129;
}

.hot-count {
  font-size: 24rpx;
  color: #86909C;
}

.search-results {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.results-header {
  font-size: 28rpx;
  color: #86909C;
  margin-bottom: 20rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  gap: 20rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-brand {
  font-size: 24rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.product-sku {
  font-size: 22rpx;
  color: #86909C;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.product-tag {
  background-color: #E8F4FF;
  color: #165DFF;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #165DFF;
}

.product-add-btn {
  background-color: #165DFF;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #86909C;
}

