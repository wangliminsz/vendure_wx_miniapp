<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <image src="/static/icons/search.png" mode="aspectFit" class="search-icon"></image>
      <input type="text" class="search-input" value="{{searchKeyword}}" bindinput="onSearchInput"  placeholder=" 搜索型号/品牌/编码" bindconfirm="onSearchConfirm" focus />
      <view class="search-cancel-btn" bindtap="onCancel">
        <text class="cancel-icon">✕</text>
      </view>
    </view>
    <view class="search-button-wrapper">
      <text class="search-btn" bindtap="onSearchConfirm">搜索</text>
    </view>
  </view>

  <!-- 搜索内容 -->
  <view class="search-content">
    <!-- 搜索历史 -->
    <view class="search-history" wx:if="{{!showSearchResults && searchHistory.length > 0}}">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="section-action" bindtap="onClearHistory">清除</text>
      </view>
      <view class="history-tags">
        <text class="history-tag" wx:for="{{searchHistory}}" wx:key="index" bindtap="onHistoryTap" data-keyword="{{item}}">{{item}}</text>
      </view>
    </view>

    <!-- 热门搜索 -->
    <view class="hot-search" wx:if="{{!showSearchResults}}">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="hot-list">
        <view class="hot-item" wx:for="{{hotSearch}}" wx:key="index" bindtap="onHistoryTap" data-keyword="{{item.keyword}}">
          <text class="hot-rank {{index < 3 ? 'top' : ''}}">{{index + 1}}</text>
          <view class="hot-info">
            <text class="hot-keyword">{{item.keyword}}</text>
            <text class="hot-count">{{item.count}} 次搜索</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 搜索结果 SCROLL-VIEW -->
    <scroll-view class="search-results" wx:if="{{showSearchResults}}" scroll-y bindscrolltolower="onReachBottom" bindscroll="onScroll" scroll-top="{{scrollTop}}" lower-threshold="50">
      <!-- 搜索结果头部 -->
      <view class="results-header">
        <text wx:if="{{loading}}">搜索中...</text>
        <text wx:elif="{{isSearchInitiated}}">找到 {{totalResults}} 个结果</text>
      </view>

      <view class="product-list">
        <view class="product-item" wx:for="{{searchResults}}" wx:key="variantId" bindtap="goToProduct" data-id="{{item.variantId}}" data-slug="{{item.productSlug}}">
          <image src="{{item.image}}" mode="aspectFill" class="product-image" lazy-load></image>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>

            <view class="flex justify-between" style="margin-bottom: 12rpx;">
              <view>
                <text class="product-brand">{{item.productName}}</text>
              </view>
              <view>
                <text class="product-sku">{{item.sku}}</text>
              </view>
            </view>

            <view class="product-tags" wx:if="{{item.options.length > 0}}">
              <text class="product-tag" wx:for="{{item.options}}" wx:for-item="option" wx:key="id">{{option.name}}</text>
            </view>
            <view class="product-footer">
              <text class="product-price">¥ {{item.price}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{showSearchResults && isSearchInitiated && totalResults === 0 && !loading}}">
        <text>未找到相关商品</text>
      </view>
    </scroll-view>
  </view>

  <!-- 回到顶部按钮 -->
  <view wx:if="{{showBackToTop}}" class="back-to-top" bindtap="scrollToTop">
    <image src="/static/images/up-arrow.svg" mode="aspectFit" class="back-to-top-icon"></image>
  </view>
</view>
