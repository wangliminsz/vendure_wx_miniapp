.container {
  min-height: 100vh;
  background-color: #F2F3F5;
  padding-bottom: 120rpx;
}

.cart-list {
  padding: 16rpx;
}

.cart-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.item-checkbox {
  padding-top: 60rpx;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  color: #1D2129;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.item-sku {
  font-size: 22rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.item-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-price {
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.item-stock {
  font-size: 22rpx;
  color: #86909C;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: #F2F3F5;
  border-radius: 8rpx;
  width: fit-content;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1D2129;
}

.quantity-btn.minus {
  border-right: 1rpx solid #E5E6EB;
}

.quantity-btn.plus {
  border-left: 1rpx solid #E5E6EB;
}

.quantity-input {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1D2129;
}

.item-delete {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #FF4D4F;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #86909C;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.go-shopping-btn {
  background-color: #165DFF;
  color: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #1D2129;
}

.total-section {
  flex: 1;
  margin-left: 24rpx;
}

.total-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.total-label {
  font-size: 28rpx;
  color: #1D2129;
}

.total-price {
  font-size: 36rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.total-hint {
  font-size: 22rpx;
  color: #86909C;
  display: block;
  margin-top: 4rpx;
}

.checkout-btn {
  background-color: #165DFF;
  color: #ffffff;
  padding: 24rpx 48rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-left: 16rpx;
}

.checkout-btn[disabled] {
  background-color: #86909C;
}
