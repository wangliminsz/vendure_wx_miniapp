.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 页面标题 */
.page-header {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-header-left {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.page-desc {
  display: block;
  font-size: 26rpx;
  color: #86909C;
}

.search-box {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
  width: 240rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.clear-icon-wrapper {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 10rpx;
}

.clear-icon {
  font-size: 40rpx;
  color: #86909C;
  line-height: 1.5;
  margin-bottom: 2px;
}

.search-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 18rpx;
  /* background-color: #165DFF; */
  border-radius: 16rpx;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #86909C;
  font-size: 28rpx;
}

/* 排序选项 */
.sort-section {
  background-color: #ffffff;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.sort-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.sort-options {
  display: flex;
  gap: 20rpx;
}

.sort-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid #E5E6EB;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fafafa;
  transition: all 0.3s;
}

.sort-option.active {
  border-color: #165DFF;
  background-color: #e6f4ff;
  color: #165DFF;
  font-weight: 500;
}

.sort-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 添加/编辑表单 */
.address-form {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-header {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #E5E6EB;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-back-btn {
  font-size: 28rpx;
  color: #165DFF;
  font-weight: 500;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.form-content {
  padding: 0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #E5E6EB;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #E5E6EB;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

/* 复选框 */
.checkbox-group {
  margin: 30rpx 0;
}

.checkbox-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.checkbox-label {
  font-size: 28rpx;
  color: #333;
  margin-left: 10rpx;
}

/* 表单按钮 */
.form-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-save {
  flex: 1;
  height: 88rpx;
  background-color: #165DFF;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background-color: #ffffff;
  color: #666;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 1rpx solid #E5E6EB;
}

/* 地址列表 */
.address-list {
  padding: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #86909C;
}

/* 地址卡片 */
.address-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.address-badges {
  display: flex;
  gap: 15rpx;
}

.badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge.default-shipping {
  background-color: #e8f5e9;
  color: #0e8146;
}

.badge.default-billing {
  background-color: #e3f2fd;
  color: #1565c0;
}

/* 操作按钮 */
.address-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: flex-end;
}

.action-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  color: #165DFF;
  background-color: #e6f4ff;
}

.action-btn.delete {
  color: #FF7D00;
  background-color: #fff2f0;
}

/* 添加地址按钮 */
.add-address-btn-wrapper {
  margin-top: 30rpx;
}

.add-address-btn {
  width: 100%;
  height: 88rpx;
  background-color: #ffffff;
  color: #165DFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx dashed #165DFF;
}

/* 返回按钮 */
.back-btn-wrapper {
  margin-top: 20rpx;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background-color: #ffffff;
  color: #86909C;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx solid #86909C;
}

/* 删除确认弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-message {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  text-align: center;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
  border: none;
}

.modal-btn.confirm {
  background-color: #FF7D00;
  color: #ffffff;
  border: none;
}
