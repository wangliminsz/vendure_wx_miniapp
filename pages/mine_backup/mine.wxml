<view class="container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <image src="{{userInfo.avatar || '/static/images/default-avatar.png'}}" class="user-avatar" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-name">{{userInfo.name || '用户'}}</text>
        <text class="user-mobile">{{userInfo.mobile || '未绑定手机号'}}</text>
      </view>
      <text class="user-arrow">></text>
    </view>
    
    <!-- 未登录状态 -->
    <view class="user-info login-area" wx:else>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image src="{{userInfo.avatar || '/static/images/default-avatar.png'}}" class="user-avatar" mode="aspectFill"></image>
      </button>
      <view class="user-detail">
        <input 
          type="nickname" 
          class="nickname-input" 
          placeholder="请输入昵称" 
          value="{{userInfo.name}}"
          bindinput="onNicknameInput"
        />
      </view>
      <button class="login-btn" bindtap="onLogin">登录</button>
    </view>
  </view>

  <!-- 手机号绑定区域 -->
  <view class="mobile-section" wx:if="{{isLoggedIn && !userInfo.mobile}}">
    <view class="mobile-card">
      <text class="mobile-label">绑定手机号</text>
      <button class="mobile-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
        <text>获取手机号</text>
      </button>
    </view>
  </view>

  <!-- 企业信息卡片 -->
  <view class="company-card" wx:if="{{isLoggedIn}}">
    <view class="company-info-row">
      <text class="company-label">企业名称</text>
      <text class="company-value">{{customerInfo.company || '未认证'}}</text>
    </view>
    <view class="company-info-row">
      <text class="company-label">企业等级</text>
      <text class="company-value level">{{customerInfo.level || '普通会员'}}</text>
    </view>
    <view class="company-info-row">
      <text class="company-label">账期额度</text>
      <text class="company-value">¥{{customerInfo.creditLimit || '0.00'}}</text>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="section-more" bindtap="goToOrders">
        <text>全部订单</text>
        <text class="arrow">></text>
      </view>
    </view>
    <view class="order-tabs">
      <view class="order-tab" bindtap="goToOrders" data-status="pending">
        <image src="/static/icons/order-pending.png" mode="aspectFit"></image>
        <text>待审批</text>
      </view>
      <view class="order-tab" bindtap="goToOrders" data-status="paid">
        <image src="/static/icons/order-paid.png" mode="aspectFit"></image>
        <text>待付款</text>
      </view>
      <view class="order-tab" bindtap="goToOrders" data-status="shipped">
        <image src="/static/icons/order-shipped.png" mode="aspectFit"></image>
        <text>待发货</text>
      </view>
      <view class="order-tab" bindtap="goToOrders" data-status="completed">
        <image src="/static/icons/order-completed.png" mode="aspectFit"></image>
        <text>已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPage" data-url="/pages/address/address">
        <text class="menu-text">收货地址</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-url="/pages/invoice/invoice">
        <text class="menu-text">发票管理</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-url="/pages/approval/approval">
        <text class="menu-text">采购审批</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-url="/pages/statement/statement">
        <text class="menu-text">对账管理</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 其他功能 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPage" data-url="/pages/setting/setting">
        <text class="menu-text">设置</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="contactService">
        <text class="menu-text">联系客服</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>
