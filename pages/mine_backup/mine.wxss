.container {
  min-height: 100vh;
  background-color: #F2F3F5;
}

.user-header {
  background: linear-gradient(135deg, #165DFF 0%, #4080FF 100%);
  padding: 48rpx 32rpx;
  padding-top: calc(48rpx + env(safe-area-inset-top));
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #ffffff;
  margin-right: 24rpx;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.user-company {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.user-arrow {
  font-size: 32rpx;
  color: #ffffff;
}

.login-area {
  justify-content: space-between;
}

.login-area .login-btn {
  background-color: rgba(255, 255, 255, 0.9);
  color: #165DFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  border: none;
}

.avatar-btn {
  padding: 0;
  margin-right: 24rpx;
  border: none;
  background: transparent;
}

.avatar-btn::after {
  border: none;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
  background: transparent;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  padding-bottom: 8rpx;
}

.user-mobile {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.mobile-section {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.mobile-card {
  background-color: #fff8e1;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mobile-label {
  font-size: 28rpx;
  color: #d48806;
  font-weight: 500;
}

.mobile-btn {
  background-color: #ffc517;
  color: #d48806;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  border: none;
}

.company-card {
  background-color: #ffffff;
  margin: -32rpx 32rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.company-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.company-info-row:last-child {
  border-bottom: none;
}

.company-label {
  font-size: 28rpx;
  color: #86909C;
}

.company-value {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
}

.company-value.level {
  color: #FF7D00;
}

.section {
  background-color: #ffffff;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F2F3F5;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #86909C;
}

.section-more .arrow {
  margin-left: 8rpx;
}

.order-tabs {
  display: flex;
  padding: 32rpx 16rpx;
}

.order-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-tab image {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.order-tab text {
  font-size: 24rpx;
  color: #1D2129;
}

.menu-list {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1D2129;
}

.menu-arrow {
  font-size: 28rpx;
  color: #86909C;
}

.logout-section {
  padding: 32rpx;
}

.logout-btn {
  background-color: #ffffff;
  color: #FF4D4F;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
}
