<view class="container">
  <!-- 状态标签 -->
  <view class="status-tabs">
    <view
      class="status-tab {{activeStatus === 'all' ? 'active' : ''}}"
      bindtap="onStatusChange"
      data-status="all"
    >
      全部
    </view>
    <view
      class="status-tab {{activeStatus === 'pending' ? 'active' : ''}}"
      bindtap="onStatusChange"
      data-status="pending"
    >
      待审批
    </view>
    <view
      class="status-tab {{activeStatus === 'paid' ? 'active' : ''}}"
      bindtap="onStatusChange"
      data-status="paid"
    >
      待付款
    </view>
    <view
      class="status-tab {{activeStatus === 'shipped' ? 'active' : ''}}"
      bindtap="onStatusChange"
      data-status="shipped"
    >
      待发货
    </view>
    <view
      class="status-tab {{activeStatus === 'completed' ? 'active' : ''}}"
      bindtap="onStatusChange"
      data-status="completed"
    >
      已完成
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-code">订单号: {{item.code}}</text>
        <text class="order-status status-{{item.state}}">{{getStatusText(item.state)}}</text>
      </view>

      <view class="order-products">
        <view class="product-item" wx:for="{{item.products}}" wx:key="index" wx:for-item="product">
          <image src="{{product.image}}" mode="aspectFill" class="product-image"></image>
          <view class="product-info">
            <text class="product-name">{{product.name}}</text>
            <text class="product-sku">料号: {{product.sku}}</text>
          </view>
          <view class="product-price-qty">
            <text class="product-price">¥{{product.price}}</text>
            <text class="product-qty">x{{product.quantity}}</text>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <view class="order-info">
          <text class="order-time">{{item.createdAt}}</text>
          <text class="order-total">合计: ¥{{item.total}}</text>
        </view>
        <view class="order-actions">
          <button class="action-btn" wx:if="{{item.state === 'paid'}}" catchtap="onRemindShip" data-id="{{item.id}}">提醒发货</button>
          <button class="action-btn primary" wx:if="{{item.state === 'completed'}}" catchtap="onBuyAgain" data-id="{{item.id}}">再次购买</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <image src="/static/images/empty-order.png" mode="aspectFit"></image>
    <text>暂无订单</text>
    <button class="go-shopping-btn" bindtap="goShopping">去采购</button>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:else bindtap="loadMore">加载更多</text>
  </view>
</view>
