.container {
  min-height: 100vh;
  background-color: #F2F3F5;
}

.status-tabs {
  display: flex;
  background-color: #ffffff;
  padding: 24rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #86909C;
  padding: 16rpx 0;
  position: relative;
}

.status-tab.active {
  color: #165DFF;
  font-weight: bold;
}

.status-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #165DFF;
  border-radius: 3rpx;
}

.order-list {
  padding: 16rpx;
}

.order-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F2F3F5;
}

.order-code {
  font-size: 26rpx;
  color: #1D2129;
}

.order-status {
  font-size: 26rpx;
}

.order-status.status-pending {
  color: #FF7D00;
}

.order-status.status-paid {
  color: #165DFF;
}

.order-status.status-shipped {
  color: #00B42A;
}

.order-status.status-completed {
  color: #86909C;
}

.order-products {
  margin-bottom: 16rpx;
}

.product-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F3F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: #1D2129;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.product-sku {
  font-size: 22rpx;
  color: #86909C;
}

.product-price-qty {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.product-price {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
}

.product-qty {
  font-size: 24rpx;
  color: #86909C;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2F3F5;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-time {
  font-size: 22rpx;
  color: #86909C;
}

.order-total {
  font-size: 28rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  background-color: #ffffff;
  color: #1D2129;
  border: 1rpx solid #E5E6EB;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.action-btn.primary {
  background-color: #165DFF;
  color: #ffffff;
  border: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #86909C;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.go-shopping-btn {
  background-color: #165DFF;
  color: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #86909C;
  font-size: 28rpx;
}
