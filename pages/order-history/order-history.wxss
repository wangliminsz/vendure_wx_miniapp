.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: 20rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.sort-btn {
  display: flex;
  align-items: center;
  margin-left: auto;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #666;
}

.sort-icon {
  margin-left: 8rpx;
  font-size: 24rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.filter-item.active {
  background-color: #1677FF;
  color: #fff;
}

.order-list {
  padding: 20rpx;
}

.loading, .empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-code {
  font-size: 26rpx;
  color: #666;
}

.order-state {
  font-size: 26rpx;
  font-weight: 500;
}

.order-state.AddingItems { color: #999; }
.order-state.ArrangingPayment { color: #FF7D00; }
.order-state.PaymentAuthorized { color: #00B42A; }
.order-state.PaymentSettled { color: #1677FF; }
.order-state.Cancelled { color: #F53F3F; }

.order-content {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-items {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.order-count {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.order-date {
  font-size: 24rpx;
  color: #999;
}

.order-total {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
}

.total-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #F53F3F;
}