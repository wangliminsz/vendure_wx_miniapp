page {
  background-color: #F2F3F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
  background-color: #F2F3F5;
}

.wx-toast {
  padding: 20rpx 40rpx !important; /* MORE PADDING */
  max-width: 80% !important;       /* Bigger width */
  font-size: 28rpx !important;    /* Text size */
  border-radius: 12rpx !important;
}

.flex {
  display: flex;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.w-full {
  width: 100%;
}

.h-full {
  height: 100%;
}

.px-4 {
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.py-4 {
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.gap-2 {
  gap: 16rpx;
}

.gap-4 {
  gap: 32rpx;
}

.text-sm {
  font-size: 24rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 48rpx;
}

.font-medium {
  font-weight: 500;
}

.font-bold {
  font-weight: bold;
}

.text-primary {
  color: #165DFF;
}

.text-secondary {
  color: #FF7D00;
}

.text-success {
  color: #00B42A;
}

.text-muted {
  color: #86909C;
}

.text-white {
  color: #ffffff;
}

.text-gray-900 {
  color: #1D2129;
}

.text-gray-600 {
  color: #4B5563;
}

.bg-primary {
  background-color: #165DFF;
}

.bg-white {
  background-color: #ffffff;
}

.bg-gray-50 {
  background-color: #F9FAFB;
}

.bg-gray-100 {
  background-color: #F3F4F6;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background-color: #165DFF;
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-secondary {
  background-color: #ffffff;
  color: #165DFF;
  border: 2rpx solid #165DFF;
  border-radius: 44rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.price {
  color: #FF4D4F;
  font-size: 32rpx;
  font-weight: bold;
}

.price-small {
  color: #FF4D4F;
  font-size: 24rpx;
  font-weight: bold;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  background-color: #FFF7E6;
  color: #FF7D00;
}

.tag-success {
  background-color: #F6FFED;
  color: #00B42A;
}

.tag-primary {
  background-color: #E6F4FF;
  color: #165DFF;
}

.goods-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.goods-image {
  width: 100%;
  height: 340rpx;
  background-color: #f5f5f5;
}

.goods-info {
  padding: 16rpx;
}

.goods-title {
  font-size: 28rpx;
  color: #1D2129;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goods-price {
  color: #FF4D4F;
  font-size: 32rpx;
  font-weight: bold;
}

.goods-stock {
  font-size: 22rpx;
  color: #86909C;
}

.search-bar {
  background-color: #165DFF;
  padding: 16rpx 32rpx;
  padding-bottom: 24rpx;
}

.search-input {
  background-color: #ffffff;
  border-radius: 36rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  /* padding: 0 32rpx; */
}

.search-input input {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
}

.banner {
  width: 100%;
  height: 360rpx;
}

.banner image {
  width: 100%;
  height: 100%;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
  padding: 24rpx 32rpx;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 32rpx;
  background-color: #165DFF;
  margin-right: 16rpx;
  vertical-align: middle;
}

.quick-entry {
  display: flex;
  flex-wrap: wrap;
  background-color: #ffffff;
  padding: 24rpx 16rpx;
}

.quick-entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.quick-entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background-color: #F2F3F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-entry-icon image {
  width: 64rpx;
  height: 64rpx;
}

.quick-entry-text {
  font-size: 24rpx;
  color: #1D2129;
}

.activity-section {
  padding: 0 32rpx;
}

.activity-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1D2129;
  margin-bottom: 16rpx;
}

.activity-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.activity-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #86909C;
  font-size: 28rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading::before {
  content: '';
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #165DFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

page {
  --van-primary-color: #165DFF;
}
