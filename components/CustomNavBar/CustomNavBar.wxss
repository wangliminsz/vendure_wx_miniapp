.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #ffffff;
}

.nav-bar-status-bar {
  width: 100%;
  background-color: #ffffff;
}

.nav-bar-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: left;
}

.nav-bar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-dots {
  display: flex;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #999;
  border-radius: 50%;
}

.nav-circle {
  width: 56rpx;
  height: 56rpx;
  background-color: #f5f5f5;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.circle-inner {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.circle-line {
  position: absolute;
  width: 100%;
  height: 2rpx;
  background-color: #999;
  top: 50%;
  transform: translateY(-50%) rotate(45deg);
}

.circle-line:nth-child(2) {
  transform: translateY(-50%) rotate(-45deg);
}

.nav-bar-placeholder {
  width: 100%;
}